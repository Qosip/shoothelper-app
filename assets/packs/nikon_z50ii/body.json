{
  "id": "nikon_z50ii",
  "brand_id": "nikon",
  "mount_id": "nikon_z",
  "name": "Nikon Z50 II",
  "display_name": "Z50 II",
  "sensor_size": "aps-c",
  "crop_factor": 1.5,
  "firmware_versions": ["1.0"],
  "current_firmware": "1.0",
  "supported_languages": ["en", "fr"],
  "release_year": 2024,
  "support_level": "full",

  "spec": {
    "sensor": {
      "megapixels": 20.9,
      "iso_range": { "min": 100, "max": 51200 },
      "iso_extended_range": { "min": 100, "max": 204800 },
      "iso_usable_max": 6400,
      "dynamic_range_ev": 13.0,
      "has_ibis": false,
      "ibis_stops": null,
      "sensor_width_mm": 23.5,
      "sensor_height_mm": 15.7
    },
    "shutter": {
      "mechanical_min_seconds": 0.00025,
      "mechanical_max_seconds": 30.0,
      "has_bulb": true,
      "electronic_min_seconds": 0.0000625,
      "electronic_max_seconds": 30.0,
      "flash_sync_speed": "1/200"
    },
    "autofocus": {
      "system": "hybrid_pdaf",
      "points": 209,
      "modes": ["af-s", "af-c", "af-f", "mf"],
      "areas": ["auto-area", "wide-area-l", "wide-area-s", "single-point", "subject-tracking"],
      "subject_detection": ["people", "dog_cat", "bird", "car_motorcycle_bicycle", "airplane_train"],
      "has_eye_af": true,
      "eye_af_modes": ["af-s", "af-c"],
      "min_ev": -4.0,
      "touch_af": true
    },
    "metering": {
      "modes": ["matrix", "center-weighted", "spot", "highlight-weighted"]
    },
    "exposure": {
      "modes": ["P", "S", "A", "M"],
      "compensation_range": { "min": -5.0, "max": 5.0, "step": 0.3 },
      "bracketing": {
        "exposure_max_shots": 5,
        "exposure_max_ev_step": 3.0,
        "focus_bracket": false
      }
    },
    "white_balance": {
      "presets": ["auto", "natural-light-auto", "direct-sunlight", "cloudy", "shade", "incandescent", "fluorescent", "flash"],
      "custom_kelvin_min": 2500,
      "custom_kelvin_max": 10000,
      "custom_kelvin_step": 10,
      "custom_slots": 6
    },
    "file_formats": {
      "photo": ["raw-nef", "jpeg", "raw+jpeg"],
      "raw_format": "NEF",
      "jpeg_quality_levels": ["fine", "normal", "basic"],
      "video": ["4k-30", "fhd-120"]
    },
    "stabilization": {
      "has_ibis": false,
      "ibis_stops": null,
      "ibis_axes": null
    },
    "drive": {
      "modes": ["single", "continuous-hi", "continuous-hi-ext", "continuous-lo", "self-timer"],
      "continuous_fps_hi": 11.0,
      "continuous_fps_mid": 5.0,
      "continuous_fps_hi_ext": 30.0,
      "continuous_fps_lo": 3.0
    }
  },

  "controls": {
    "dials": [
      {
        "id": "command_dial",
        "position": "rear_top_right",
        "label": { "en": "Command dial", "fr": "Molette de commande" },
        "default_function": {
          "mode_M": "shutter_speed",
          "mode_A": "exposure_compensation",
          "mode_S": "shutter_speed",
          "mode_P": "program_shift"
        }
      },
      {
        "id": "sub_command_dial",
        "position": "front_top_right",
        "label": { "en": "Sub-command dial", "fr": "Molette secondaire" },
        "default_function": {
          "mode_M": "aperture",
          "mode_A": "aperture",
          "mode_S": "exposure_compensation",
          "mode_P": "exposure_compensation"
        }
      }
    ],
    "buttons": [
      {
        "id": "af_on",
        "position": "rear_top_right",
        "label": { "en": "AF-ON", "fr": "AF-ON" },
        "default_function": "af_activate",
        "customizable": true
      },
      {
        "id": "i_button",
        "position": "rear_right",
        "label": { "en": "i", "fr": "i" },
        "default_function": "i_menu",
        "customizable": false
      },
      {
        "id": "fn1",
        "position": "front_left",
        "label": { "en": "Fn1", "fr": "Fn1" },
        "default_function": "white_balance",
        "customizable": true
      },
      {
        "id": "fn2",
        "position": "rear_left",
        "label": { "en": "Fn2", "fr": "Fn2" },
        "default_function": "focus_mode",
        "customizable": true
      }
    ],
    "fn_menu_items": [
      "image_quality", "image_size", "white_balance", "iso_sensitivity",
      "focus_mode", "af_area_mode", "release_mode", "metering",
      "vibration_reduction", "active_d_lighting"
    ]
  }
}
